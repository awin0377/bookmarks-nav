# Neon PostgreSQL 连接串
# 从 Neon Console → Connection Details → Connection string 复制
DATABASE_URL=postgresql://...

# DeepSeek API Key（AI 自然语言搜索 & 智能描述）
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-...

# 访问密码（默认 123456）
PASSWORD=123456

# Cron 定时任务密钥（死链巡检用）
# 生成随机字符串: openssl rand -hex 16
CRON_SECRET=your-random-secret-here
